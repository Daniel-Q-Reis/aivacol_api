  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const loginPath = '/api/v1/auth/login';",
          "const token = pm.collectionVariables.get('token');",
          "const expiryRaw = pm.collectionVariables.get('token_expires_at');",
          "const expiry = expiryRaw ? Number(expiryRaw) : 0;",
          "const now = Date.now();",
          "const currentPath = pm.request.url.getPath();",
          "const mustSkip = currentPath.endsWith(loginPath);",
          "",
          "if (mustSkip) {",
          "  return;",
          "}",
          "",
          "if (token && expiry > now + 15000) {",
          "  return;",
          "}",
          "",
          "const baseUrl = pm.collectionVariables.get('base_url');",
          "const nickname = pm.collectionVariables.get('nickname');",
          "const password = pm.collectionVariables.get('password');",
          "",
          "pm.sendRequest({",
          "  url: `${baseUrl}${loginPath}`,",
          "  method: 'POST',",
          "  header: { 'Content-Type': 'application/json' },",
          "  body: {",
          "    mode: 'raw',",
          "    raw: JSON.stringify({ nickname, password })",
          "  }",
          "}, (err, res) => {",
          "  if (err || !res || res.code >= 300) {",
          "    throw new Error(`Failed to auto-fetch token: ${err ? err.message : res ? res.code : 'unknown error'}`);",
          "  }",
          "",
          "  const data = res.json();",
          "  if (!data.access_token) {",
          "    throw new Error('Login response does not include access_token');",
          "  }",
          "",
          "  pm.collectionVariables.set('token', data.access_token);",
          "  pm.collectionVariables.set('token_expires_at', String(Date.now() + 55 * 60 * 1000));",
          "});"
        ]
      }
    }
  ],
